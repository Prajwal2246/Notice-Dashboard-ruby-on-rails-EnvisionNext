<div class="container mx-auto px-4 py-8 max-w-2xl">
  <%= link_to '← Back to Notice Board', notices_path, class: "text-blue-600 hover:underline mb-6 inline-block" %>

  <div class="bg-white border rounded-lg shadow-md p-8 <%= 'border-yellow-400 ring-2 ring-yellow-200' if @notice.pinned %>">
    <div class="flex justify-between items-start mb-4">
      <span class="px-3 py-1 text-sm font-semibold rounded bg-blue-100 text-blue-800 uppercase">
        <%= @notice.category %>
      </span>
      <% if @notice.pinned %>
        <span class="text-yellow-600 font-bold">📌 Pinned Notice</span>
      <% end %>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= @notice.title %></h1>
    
    <div class="prose max-w-none text-gray-700 mb-8">
      <%= simple_format @notice.body %>
    </div>

    <div class="border-t border-gray-100 pt-6 flex justify-between items-center text-sm">
      <div>
        <p class="text-gray-500">Posted by</p>
        <p class="font-bold text-gray-900 text-lg"><%= @notice.author_name %></p>
        <p class="text-gray-400"><%= @notice.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>
      
      <div>
        <%= button_to 'Delete Notice', @notice, method: :delete, 
            data: { confirm: 'Are you sure you want to remove this notice?' }, 
            class: "bg-red-50 text-red-600 hover:bg-red-100 px-3.5 py-2 rounded-md transition" %>
      </div>
    </div>
  </div>
</div>